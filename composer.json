{
    "name": "sportclimbing/calendar-backend",
    "type": "project",
    "prefer-stable": true,
    "minimum-stability": "dev",
    "require": {
        "php": ">=8.5",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "php-di/slim-bridge": "^3.0",
        "sportclimbing/ifsc-ics-generator": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "mockery/mockery": "^2.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SportClimbing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SportClimbing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    }
}
